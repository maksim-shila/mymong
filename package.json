{
  "name": "mymong",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:app": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build:web": "tsc && vite build",
    "build": "npm run build:web",
    "dist:app": "npm run build:web && electron-packager . MyMong --platform=win32 --arch=x64 --out=release --overwrite --prune=true --ignore=\"^/src$\" --ignore=\"^/assets$\" --ignore=\"^/\\.vscode$\" --ignore=\"^/\\.git$\"",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^37.2.6",
    "@electron/packager": "^18.4.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0-beta.13",
    "wait-on": "^9.0.3"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
